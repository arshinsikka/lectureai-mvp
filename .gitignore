# ── Environment ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Testing ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Session data (runtime — never commit) ────────────────────────────
data/*
!data/.gitkeep
outputs/*
!outputs/.gitkeep

# ── Test / demo media ────────────────────────────────────────────────
test_data/

# ── OS artifacts ─────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.icloud

# ── Editors ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Node (frontend tooling, if ever added) ────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log

# ── Logs ──────────────────────────────────────────────────────────────
*.log
logs/

# ── Claude Code ───────────────────────────────────────────────────────
.claude/

# ── Word temp files ───────────────────────────────────────────────────
~$*
