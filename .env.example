# ── LectureAI Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── OpenAI ───────────────────────────────────────────────────────────
# Used for Whisper transcription (whisper-1 model)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Google AI ────────────────────────────────────────────────────────
# Used for Gemini 2.0 Flash (correction, summarisation, translation)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# ── Email delivery (Gmail SMTP) ──────────────────────────────────────
# Use a Gmail account with an App Password (not your main password).
# Guide: https://support.google.com/accounts/answer/185833
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# The address that notes will be sent TO (can be the same as SMTP_EMAIL)
RECIPIENT_EMAIL=recipient@example.com

# ── Optional overrides ────────────────────────────────────────────────
# DATA_DIR=data          # Directory for session input files
# OUTPUTS_DIR=outputs    # Directory for generated output files
